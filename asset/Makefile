.PHONY: all clean

all: github.svg mastodon.svg email.svg

github.svg:
	wget -nv -O github.svg https://icons.getbootstrap.com/assets/icons/github.svg

mastodon.svg:
	wget -nv -O mastodon.svg https://icons.getbootstrap.com/assets/icons/mastodon.svg

email.svg:
	wget -nv -O email.svg https://icons.getbootstrap.com/assets/icons/envelope.svg

clean:
	$(RM) *.svg
